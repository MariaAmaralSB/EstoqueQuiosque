<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EstoqueQuiosque.App.Models"
             x:Class="EstoqueQuiosque.App.Pages.EstoquePage"
             Title="Conferir Produtos">

    <ScrollView>
        <VerticalStackLayout Padding="32,24" Spacing="16">

            <Label Text="Conferir Produtos" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Visualize e gerencie seu estoque" Style="{StaticResource PageSubtitleStyle}" />

            <ActivityIndicator IsRunning="{Binding IsCarregando}"
                               IsVisible="{Binding IsCarregando}"
                               Color="#3B82F6"
                               HeightRequest="40" />

            <Frame Style="{StaticResource SectionCardStyle}" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Entry Placeholder="🔍  Buscar por nome ou código..."
                               Text="{Binding TextoBusca}" />
                        <Picker Grid.Column="1"
                                MinimumWidthRequest="200"
                                ItemsSource="{Binding Categorias}"
                                SelectedItem="{Binding CategoriaSelecionada}" />
                    </Grid>
                    <Button Text="⚠ Estoque Baixo"
                            HorizontalOptions="Start"
                            Padding="14,8"
                            BackgroundColor="{Binding FiltroEstoqueBaixoCorFundo}"
                            Command="{Binding ToggleFiltroEstoqueBaixoCommand}" />
                </VerticalStackLayout>
            </Frame>

            <CollectionView ItemsSource="{Binding ProdutosFiltrados}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Produto">
                        <Frame Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="14">

                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Label Text="{Binding Nome}" FontAttributes="Bold" FontSize="15" />
                                    <Frame IsVisible="{Binding AbaixoDoMinimo}"
                                           BackgroundColor="#431407"
                                           BorderColor="#9A3412"
                                           CornerRadius="20"
                                           Padding="10,3"
                                           HasShadow="False">
                                        <Label Text="⚠ Estoque Baixo"
                                               TextColor="#FB923C" FontAttributes="Bold" FontSize="11" />
                                    </Frame>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Button Text="📥"
                                            BackgroundColor="Transparent"
                                            TextColor="#60A5FA"
                                            FontSize="15"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RegistrarEntradaCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="💰"
                                            BackgroundColor="Transparent"
                                            TextColor="#4ADE80"
                                            FontSize="15"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RegistrarVendaCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="✏"
                                            BackgroundColor="Transparent"
                                            TextColor="#60A5FA"
                                            FontSize="15"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarProdutoCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="🗑"
                                            BackgroundColor="Transparent"
                                            TextColor="#F87171"
                                            FontSize="15"
                                            Padding="8,4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoverProdutoCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>

                                <Grid Grid.Row="1" Grid.ColumnSpan="2"
                                      ColumnDefinitions="*,*,*,*">

                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="Código" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding Codigo}" FontSize="13" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="Categoria" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding Categoria}" FontSize="13" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                                        <Label Text="Quantidade" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding QuantidadeFormatada}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{Binding AbaixoDoMinimo, Converter={StaticResource LowStockColorConverter}}" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="3" Spacing="3">
                                        <Label Text="Preço" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding PrecoVenda, StringFormat='R$ {0:F2}'}"
                                               FontSize="13" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Frame Style="{StaticResource StatusFrameStyle}">
                <Label Text="{Binding MensagemStatus}" FontSize="13" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
