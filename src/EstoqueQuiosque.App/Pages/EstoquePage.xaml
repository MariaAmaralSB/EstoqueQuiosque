<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EstoqueQuiosque.App.Models"
             x:Class="EstoqueQuiosque.App.Pages.EstoquePage"
             Title="Conferir Produtos">

    <ScrollView>
        <VerticalStackLayout Padding="32,24" Spacing="18">
            <Label Text="Conferir Produtos" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Visualize e gerencie seu estoque" Style="{StaticResource PageSubtitleStyle}" />

            <Frame Style="{StaticResource SectionCardStyle}" Padding="14">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Entry Placeholder="Buscar por nome ou código..."
                           Text="{Binding TextoBusca}" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding Categorias}"
                            SelectedItem="{Binding CategoriaSelecionada}" />
                </Grid>
            </Frame>

            <CollectionView ItemsSource="{Binding ProdutosFiltrados}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Produto">
                        <Frame Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Nome}" FontAttributes="Bold" FontSize="28" />
                                    <Frame IsVisible="{Binding AbaixoDoMinimo}"
                                           BackgroundColor="#FDEBD7"
                                           BorderColor="#FDEBD7"
                                           CornerRadius="12"
                                           Padding="12,4"
                                           HasShadow="False">
                                        <Label Text="⚠ Estoque Baixo" TextColor="#C2410C" FontAttributes="Bold" FontSize="14"/>
                                    </Frame>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                    <Button Text="✏"
                                            BackgroundColor="Transparent"
                                            TextColor="#1D4ED8" />
                                    <Button Text="🗑"
                                            BackgroundColor="Transparent"
                                            TextColor="#DC2626"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoverProdutoCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>

                                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*,*" Margin="0,12,0,0">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Código" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding Codigo}" FontSize="22" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="Categoria" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding Categoria}" FontSize="22" FontAttributes="Bold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                                        <Label Text="Quantidade" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding QuantidadeAtual, StringFormat='{0} un'}"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="{Binding AbaixoDoMinimo, Converter={StaticResource LowStockColorConverter}}" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="3" Spacing="4">
                                        <Label Text="Preço" Style="{StaticResource CardLabelStyle}" />
                                        <Label Text="{Binding PrecoVenda, StringFormat='R$ {0:F2}'}" FontSize="22" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Frame Style="{StaticResource StatusFrameStyle}">
                <Label Text="{Binding MensagemStatus}" />
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
