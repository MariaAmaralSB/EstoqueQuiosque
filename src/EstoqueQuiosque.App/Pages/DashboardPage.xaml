<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EstoqueQuiosque.App.Models"
             x:Class="EstoqueQuiosque.App.Pages.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="32,24" Spacing="20">

            <Label Text="Dashboard" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Visão geral do seu estoque" Style="{StaticResource PageSubtitleStyle}" />

            <ActivityIndicator IsRunning="{Binding IsCarregando}"
                               IsVisible="{Binding IsCarregando}"
                               Color="#63B3ED"
                               HeightRequest="40" />

            <!-- 4 stat cards in one row -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">

                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Frame BackgroundColor="#1A3A5C" BorderColor="Transparent"
                               CornerRadius="10" Padding="0"
                               WidthRequest="44" HeightRequest="44"
                               HasShadow="False" HorizontalOptions="Start">
                            <Label Text="📦" FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Total de Produtos" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding TotalProdutos}" Style="{StaticResource CardValueStyle}" />
                        <Label Text="itens cadastrados" FontSize="12" TextColor="#8896A8" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Frame BackgroundColor="#143A26" BorderColor="Transparent"
                               CornerRadius="10" Padding="0"
                               WidthRequest="44" HeightRequest="44"
                               HasShadow="False" HorizontalOptions="Start">
                            <Label Text="💰" FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Valor em Estoque" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding ValorEmEstoque, StringFormat='R$ {0:N2}'}"
                               Style="{StaticResource CardValueStyle}" />
                        <Label Text="preço de venda" FontSize="12" TextColor="#8896A8" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="2" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Frame BackgroundColor="#143A30" BorderColor="Transparent"
                               CornerRadius="10" Padding="0"
                               WidthRequest="44" HeightRequest="44"
                               HasShadow="False" HorizontalOptions="Start">
                            <Label Text="✅" FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Produtos Ativos" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding ProdutosAtivos}" Style="{StaticResource CardValueStyle}" />
                        <Label Text="com estoque > 0" FontSize="12" TextColor="#8896A8" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="3" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Frame BackgroundColor="#5C3A14" BorderColor="Transparent"
                               CornerRadius="10" Padding="0"
                               WidthRequest="44" HeightRequest="44"
                               HasShadow="False" HorizontalOptions="Start">
                            <Label Text="⚠" FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Estoque Baixo" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding EstoqueBaixo}"
                               Style="{StaticResource CardValueStyle}"
                               TextColor="#F97316" />
                        <Label Text="precisam reposição" FontSize="12" TextColor="#8896A8" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- Estoque Baixo + Últimos Movimentos side by side -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                <Frame Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="⚠ ESTOQUE BAIXO"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#8896A8"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Ver todos →"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="13">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding VerProdutosCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <CollectionView ItemsSource="{Binding ProdutosEstoqueBaixoLista}">
                            <CollectionView.EmptyView>
                                <Label Text="Nenhum produto em estoque crítico."
                                       FontSize="13" TextColor="#8896A8" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Produto">
                                    <VerticalStackLayout Spacing="6" Padding="0,8">
                                        <Label Text="{Binding Nome}"
                                               FontAttributes="Bold" FontSize="14" />
                                        <Label Text="{Binding ResumoCategoriaMinimo}"
                                               FontSize="12" TextColor="#8896A8" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <ProgressBar Progress="{Binding ProgressoEstoque}"
                                                         ProgressColor="#F97316"
                                                         HeightRequest="4"
                                                         VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding QuantidadeFormatada}"
                                                   FontAttributes="Bold" FontSize="13"
                                                   TextColor="#F97316"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="↕ ÚLTIMOS MOVIMENTOS"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#8896A8"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Ver todos →"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="13">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding VerMovimentosCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <CollectionView ItemsSource="{Binding MovimentosRecentes}">
                            <CollectionView.EmptyView>
                                <Label Text="Nenhum movimento registrado."
                                       FontSize="13" TextColor="#8896A8" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:MovimentoEstoque">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                          ColumnSpacing="10"
                                          Padding="0,8">
                                        <BoxView WidthRequest="8" HeightRequest="8"
                                                 CornerRadius="4"
                                                 BackgroundColor="{Binding Tipo, Converter={StaticResource MovimentoTipoColorConverter}}"
                                                 VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding ProdutoNome}"
                                               FontSize="13"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding Data, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                               FontSize="12" TextColor="#8896A8"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="3"
                                               Text="{Binding DeltaQuantidade}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{Binding Tipo, Converter={StaticResource MovimentoTipoColorConverter}}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- Produtos por categoria -->
            <Frame Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="PRODUTOS POR CATEGORIA"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="#8896A8" />
                    <CollectionView ItemsSource="{Binding CategoriasDistribuicao}">
                        <CollectionView.EmptyView>
                            <Label Text="Nenhum produto cadastrado."
                                   FontSize="13" TextColor="#8896A8" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoriaDistribuicao">
                                <Grid ColumnDefinitions="100,*,30"
                                      ColumnSpacing="14"
                                      Padding="0,6">
                                    <Label Text="{Binding Nome}"
                                           FontSize="13"
                                           VerticalOptions="Center" />
                                    <ProgressBar Grid.Column="1"
                                                 Progress="{Binding Percentagem}"
                                                 ProgressColor="#63B3ED"
                                                 HeightRequest="6"
                                                 VerticalOptions="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding Quantidade}"
                                           FontSize="13" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
