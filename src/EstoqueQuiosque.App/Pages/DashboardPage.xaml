<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EstoqueQuiosque.App.Pages.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="32,24" Spacing="18">
            <Label Text="Dashboard" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Visão geral do seu estoque" Style="{StaticResource PageSubtitleStyle}" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Total de Produtos" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding TotalProdutos}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Valor em Estoque" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding ValorEmEstoque, StringFormat='R$ {0:N2}'}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Produtos Ativos" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding ProdutosAtivos}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Estoque Baixo" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding EstoqueBaixo}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame BackgroundColor="{StaticResource Primary}" BorderColor="{StaticResource Primary}" CornerRadius="14" Padding="22" Margin="0,10,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Bem-vindo ao Sistema de Controle de Estoque" FontSize="34" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Gerencie seus produtos de forma eficiente. Cadastre novos itens e mantenha o controle total do seu inventário."
                           FontSize="20"
                           TextColor="White" />
                    <Label Text="Comece cadastrando seus primeiros produtos na aba \"Cadastrar Produto\""
                           FontSize="18"
                           TextColor="#C7D2FE" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
