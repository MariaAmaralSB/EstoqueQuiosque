<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:EstoqueQuiosque.App.Models"
             x:Class="EstoqueQuiosque.App.Pages.CadastroProdutoPage"
             Title="Produtos">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="Cadastro de Produtos"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#111827" />

            <Label Text="Selecionar produto para editar (opcional)" TextColor="#111827" />
            <Picker ItemsSource="{Binding ProdutosCadastrados}"
                    ItemDisplayBinding="{Binding Nome}"
                    SelectedItem="{Binding ProdutoSelecionadoParaEdicao}"
                    Title="Selecione para editar" />

            <Label Text="Nome do produto" TextColor="#111827" />
            <Entry Placeholder="Ex.: Refrigerante lata"
                   Text="{Binding NomeProduto}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout>
                    <Label Text="Unidade" TextColor="#111827" />
                    <Entry Placeholder="un"
                           Text="{Binding Unidade}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Custo unitário" TextColor="#111827" />
                    <Entry Keyboard="Numeric"
                           Placeholder="0,00"
                           Text="{Binding CustoUnitario}" />
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout>
                    <Label Text="Quantidade atual" TextColor="#111827" />
                    <Entry Keyboard="Numeric"
                           Text="{Binding QuantidadeInicial}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Estoque mínimo" TextColor="#111827" />
                    <Entry Keyboard="Numeric"
                           Text="{Binding EstoqueMinimo}" />
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Cadastrar Produto"
                        Command="{Binding CadastrarProdutoCommand}" />
                <Button Grid.Column="1"
                        Text="Salvar Alterações"
                        BackgroundColor="#5B3A29"
                        Command="{Binding AtualizarProdutoCommand}" />
            </Grid>

            <Button Text="Limpar seleção"
                    BackgroundColor="#6B7280"
                    Command="{Binding LimparFormularioCommand}" />

            <Frame Padding="10">
                <Label Text="{Binding MensagemStatus}"
                       TextColor="#111827" />
            </Frame>

            <Label Text="Produtos cadastrados"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#111827" />

            <CollectionView ItemsSource="{Binding ProdutosCadastrados}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Produto">
                        <Frame Margin="0,4" Padding="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Nome}"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    <Label Text="{Binding Unidade, StringFormat='Unidade: {0}'}"
                                           TextColor="#374151" />
                                    <Label Text="{Binding QuantidadeAtual, StringFormat='Qtd atual: {0}'}"
                                           TextColor="#374151" />
                                </VerticalStackLayout>

                                <Label Grid.Column="1"
                                       Text="{Binding CustoUnitario, StringFormat='R$ {0:F2}'}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold"
                                       TextColor="#1F2937" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
