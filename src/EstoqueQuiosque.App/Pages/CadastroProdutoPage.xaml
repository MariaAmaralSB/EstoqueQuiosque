<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EstoqueQuiosque.App.Pages.CadastroProdutoPage"
             Title="Cadastrar Produto">

    <ScrollView>
        <VerticalStackLayout Padding="32,24" Spacing="18">
            <Label Text="Cadastrar Produto" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Preencha os dados do novo produto" Style="{StaticResource PageSubtitleStyle}" />

            <Frame Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="18">
                    <Label Text="Informações Básicas" FontAttributes="Bold" FontSize="32" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Nome do Produto *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Placeholder="Ex: Notebook Dell Inspiron"
                                   Text="{Binding NomeProduto}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Código do Produto *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Placeholder="Ex: PROD-001"
                                   Text="{Binding CodigoProduto}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Categoria *" Style="{StaticResource FieldLabelStyle}" />
                            <Picker Title="Selecione uma categoria"
                                    ItemsSource="{Binding Categorias}"
                                    SelectedItem="{Binding Categoria}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Quantidade em Estoque *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric"
                                   Text="{Binding QuantidadeInicial}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Informações Financeiras" FontAttributes="Bold" FontSize="32" TextColor="#047857" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Preço de Compra (R$) *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric"
                                   Placeholder="0.00"
                                   Text="{Binding CustoUnitario}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Preço de Venda (R$) *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric"
                                   Placeholder="0.00"
                                   Text="{Binding PrecoVenda}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="6">
                            <Label Text="Estoque Mínimo *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric"
                                   Text="{Binding EstoqueMinimo}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Descrição" Style="{StaticResource FieldLabelStyle}" />
                        <Editor Placeholder="Descreva detalhes adicionais do produto..."
                                AutoSize="TextChanges"
                                HeightRequest="120"
                                Text="{Binding Descricao}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
                        <Button Text="Cadastrar Produto"
                                Command="{Binding CadastrarProdutoCommand}" />
                        <Button Text="Salvar Alterações"
                                IsVisible="{Binding EstaEmEdicao}"
                                Command="{Binding AtualizarProdutoCommand}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource StatusFrameStyle}">
                <Label Text="{Binding MensagemStatus}" />
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
