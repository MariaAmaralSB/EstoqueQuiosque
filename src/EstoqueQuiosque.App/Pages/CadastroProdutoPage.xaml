<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:EstoqueQuiosque.App.Controls"
             x:Class="EstoqueQuiosque.App.Pages.CadastroProdutoPage"
             Title="Cadastrar Produto"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="52,1,*">
        <controls:TopNavigationBar Grid.Row="0" CurrentPage="Cadastrar"/>
        <BoxView Grid.Row="1" BackgroundColor="#1A2035"/>
        <ScrollView Grid.Row="2">
        <VerticalStackLayout Padding="32,24" Spacing="16">

            <Label Text="Cadastrar Produto" Style="{StaticResource PageTitleStyle}" />
            <Label Text="Preencha os dados do novo produto" Style="{StaticResource PageSubtitleStyle}" />

            <ActivityIndicator IsRunning="{Binding IsCarregando}"
                               IsVisible="{Binding IsCarregando}"
                               Color="#3B82F6"
                               HeightRequest="40" />

            <Frame Style="{StaticResource SectionCardStyle}">
                <VerticalStackLayout Spacing="20">

                    <HorizontalStackLayout Spacing="10">
                        <Frame BackgroundColor="#1A3A5C" BorderColor="#1A3A5C" CornerRadius="8"
                               Padding="0" WidthRequest="32" HeightRequest="32" HasShadow="False">
                            <Label Text="📦" FontSize="16"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Informações Básicas" FontAttributes="Bold" FontSize="15"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Nome do Produto *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Placeholder="Ex: Cerveja Spaten"
                                   Text="{Binding NomeProduto}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Código *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Placeholder="Ex: 001"
                                   Text="{Binding CodigoProduto}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="2*,*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Categoria *" Style="{StaticResource FieldLabelStyle}" />
                            <Picker ItemsSource="{Binding Categorias}"
                                    SelectedItem="{Binding Categoria}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Qtd. em Estoque *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric"
                                   Text="{Binding QuantidadeInicial}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="6">
                            <Label Text="Unidade *" Style="{StaticResource FieldLabelStyle}" />
                            <Picker ItemsSource="{Binding Unidades}"
                                    SelectedItem="{Binding Unidade}" />
                        </VerticalStackLayout>
                    </Grid>

                    <HorizontalStackLayout Spacing="10" Margin="0,6,0,0">
                        <Frame BackgroundColor="#14432A" BorderColor="#14432A" CornerRadius="8"
                               Padding="0" WidthRequest="32" HeightRequest="32" HasShadow="False">
                            <Label Text="💲" FontSize="16"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Frame>
                        <Label Text="Informações Financeiras" FontAttributes="Bold" FontSize="15"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Custo Total do Lote (R$) *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric" Placeholder="0,00"
                                   Text="{Binding CustoLote}" />
                            <Label Text="{Binding CustoUnitarioCalculado}"
                                   FontSize="11" TextColor="#4ADE80" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Preço de Venda por Unidade (R$) *" Style="{StaticResource FieldLabelStyle}" />
                            <Entry Keyboard="Numeric" Placeholder="0,00"
                                   Text="{Binding PrecoVenda}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Estoque Mínimo (aviso de reposição) *" Style="{StaticResource FieldLabelStyle}" />
                        <Entry Keyboard="Numeric"
                               Text="{Binding EstoqueMinimo}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Descrição (opcional)" Style="{StaticResource FieldLabelStyle}" />
                        <Editor Placeholder="Ex: Cerveja long neck 355ml gelada..."
                                AutoSize="TextChanges"
                                HeightRequest="100"
                                Text="{Binding Descricao}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout HorizontalOptions="End" Spacing="10" Margin="0,4,0,0">
                        <Button Text="Cadastrar Produto"
                                Command="{Binding CadastrarProdutoCommand}" />
                        <Button Text="Salvar Alterações"
                                IsVisible="{Binding EstaEmEdicao}"
                                Command="{Binding AtualizarProdutoCommand}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource StatusFrameStyle}">
                <Label Text="{Binding MensagemStatus}" FontSize="13" />
            </Frame>

        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
