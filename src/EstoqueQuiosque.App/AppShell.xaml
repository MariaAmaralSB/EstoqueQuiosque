<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EstoqueQuiosque.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:EstoqueQuiosque.App.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#2643B2"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.NavBarHasShadow="False"
    Title="Controle de Estoque">

    <TabBar Shell.TabBarBackgroundColor="#FFFFFF"
            Shell.TabBarForegroundColor="#475569"
            Shell.TabBarTitleColor="#334155"
            Shell.TabBarUnselectedColor="#64748B"
            Shell.TabBarDisabledColor="#94A3B8">
        <Tab Title="Dashboard">
            <ShellContent
                Title="Dashboard"
                ContentTemplate="{DataTemplate pages:DashboardPage}"
                Route="DashboardPage" />
        </Tab>

        <Tab Title="Cadastrar Produto">
            <ShellContent
                Title="Cadastrar Produto"
                ContentTemplate="{DataTemplate pages:CadastroProdutoPage}"
                Route="CadastroProdutoPage" />
        </Tab>

        <Tab Title="Conferir Produtos">
            <ShellContent
                Title="Conferir Produtos"
                ContentTemplate="{DataTemplate pages:EstoquePage}"
                Route="EstoquePage" />
        </Tab>
    </TabBar>

</Shell>
