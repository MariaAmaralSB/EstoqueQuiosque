<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EstoqueQuiosque.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:EstoqueQuiosque.App.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#0A0B0F"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.NavBarHasShadow="False"
    Title="Controle de Estoque">

    <TabBar Shell.TabBarBackgroundColor="#0A0B0F"
            Shell.TabBarForegroundColor="#63B3ED"
            Shell.TabBarTitleColor="#F1F5F9"
            Shell.TabBarUnselectedColor="#64748B"
            Shell.TabBarDisabledColor="#4B5563">
        <Tab Title="Dashboard">
            <ShellContent
                Title="Dashboard"
                ContentTemplate="{DataTemplate pages:DashboardPage}"
                Route="DashboardPage" />
        </Tab>

        <Tab Title="+ Cadastrar Produto">
            <ShellContent
                Title="Cadastrar Produto"
                ContentTemplate="{DataTemplate pages:CadastroProdutoPage}"
                Route="CadastroProdutoPage" />
        </Tab>

        <Tab Title="Conferir Produtos">
            <ShellContent
                Title="Conferir Produtos"
                ContentTemplate="{DataTemplate pages:EstoquePage}"
                Route="EstoquePage" />
        </Tab>

        <Tab Title="Movimentos">
            <ShellContent
                Title="Movimentos"
                ContentTemplate="{DataTemplate pages:MovimentosPage}"
                Route="MovimentosPage" />
        </Tab>
    </TabBar>

</Shell>
