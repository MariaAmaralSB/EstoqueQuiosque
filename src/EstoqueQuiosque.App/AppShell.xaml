<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EstoqueQuiosque.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:EstoqueQuiosque.App.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#2D2A32"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.NavBarHasShadow="False"
    Title="Estoque Quiosque">

    <TabBar>
        <Tab Title="Principal">
            <ShellContent
                Title="Cadastro"
                ContentTemplate="{DataTemplate pages:CadastroProdutoPage}"
                Route="CadastroProdutoPage" />
        </Tab>

        <Tab Title="Estoque">
            <ShellContent
                Title="Movimentações"
                ContentTemplate="{DataTemplate pages:EstoquePage}"
                Route="EstoquePage" />
        </Tab>
    </TabBar>

</Shell>
