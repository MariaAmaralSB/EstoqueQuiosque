<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EstoqueQuiosque.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#2D2A32</Color>
            <Color x:Key="Secondary">#6B4F4F</Color>
            <Color x:Key="PageBackground">#FFFDF7</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="TextPrimary">#1F2937</Color>
            <Color x:Key="TextSecondary">#374151</Color>
            <Color x:Key="BorderColor">#D1D5DB</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="#6B7280" />
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="TitleColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
            </Style>

            <Style TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="HasShadow" Value="False" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
