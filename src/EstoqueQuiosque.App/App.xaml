<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EstoqueQuiosque.App.Converters"
             x:Class="EstoqueQuiosque.App.App">

    <Application.Resources>
        <ResourceDictionary>

            <converters:LowStockColorConverter x:Key="LowStockColorConverter" />
            <converters:MovimentoTipoColorConverter x:Key="MovimentoTipoColorConverter" />
            <converters:MovimentoTipoBackgroundConverter x:Key="MovimentoTipoBackgroundConverter" />

            <Color x:Key="Primary">#3B82F6</Color>
            <Color x:Key="PrimaryDark">#1D4ED8</Color>

            <Color x:Key="LightPageBackground">#EEF2F7</Color>
            <Color x:Key="LightSurface">#FFFFFF</Color>
            <Color x:Key="LightTextPrimary">#0F172A</Color>
            <Color x:Key="LightTextSecondary">#475569</Color>
            <Color x:Key="LightBorder">#D7DFEA</Color>

            <Color x:Key="DarkPageBackground">#090D18</Color>
            <Color x:Key="DarkSurface">#111827</Color>
            <Color x:Key="DarkTextPrimary">#F1F5F9</Color>
            <Color x:Key="DarkTextSecondary">#8896A8</Color>
            <Color x:Key="DarkBorder">#1C2539</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightPageBackground}"
                                         Dark="{StaticResource DarkPageBackground}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="34" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PageSubtitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CardStyle" TargetType="Frame">
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightSurface}"
                                         Dark="{StaticResource DarkSurface}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightBorder}"
                                         Dark="{StaticResource DarkBorder}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="PlaceholderColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightSurface}"
                                         Dark="{StaticResource DarkSurface}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="PlaceholderColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightSurface}"
                                         Dark="{StaticResource DarkSurface}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Picker">
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="TitleColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightSurface}"
                                         Dark="{StaticResource DarkSurface}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CardLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CardValueStyle" TargetType="Label">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextPrimary}"
                                         Dark="{StaticResource DarkTextPrimary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SectionCardStyle" TargetType="Frame">
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightSurface}"
                                         Dark="{StaticResource DarkSurface}" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightBorder}"
                                         Dark="{StaticResource DarkBorder}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="{StaticResource LightTextSecondary}"
                                         Dark="{StaticResource DarkTextSecondary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusFrameStyle" TargetType="Frame">
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="#EFF6FF" Dark="#1E2D40" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderColor">
                    <Setter.Value>
                        <AppThemeBinding Light="#BFDBFE" Dark="#2E3B52" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
